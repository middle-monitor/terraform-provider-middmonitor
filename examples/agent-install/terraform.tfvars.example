# --- Middle Monitor API ---
base_url     = "https://api.middlemonitor.io"
org_slug     = "default"
access_token = "eyJhbGci..." # JWT or "mm_..." API key

# Optional: only when the receiver is exposed on a different origin than
# base_url. Left empty, agent downloads use base_url.
# receiver_base_url = ""

# --- Target machine ---
host_name    = "app-server-01"
host_address = "10.0.1.50"

# --- SSH ---
ssh_user = "ubuntu"

# Private key auth (default) ...
ssh_private_key_path = "~/.ssh/id_rsa"

# ... or password auth (leave ssh_private_key_path empty if used).
# ssh_password = "secret"
